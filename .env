# hugging face local cache dir
#HF_HOME=/mnt/cache/huggingface/

# model (huggingface)
#LLAMA_HF_REPO=TheBloke/Llama-2-7B-Chat-GGUF
#LLAMA_MODEL=llama-2-7b-chat.Q4_K_M.gguf
#
#LLAMA_HF_REPO=mmnga/tokyotech-llm-Llama-3.1-Swallow-70B-Instruct-v0.1-gguf
#LLAMA_MODEL=tokyotech-llm-Llama-3.1-Swallow-70B-Instruct-v0.1-Q4_K_M.gguf
LLAMA_HF_REPO=legraphista/Phi-3-medium-128k-instruct-IMat-GGUF
LLAMA_MODEL=Phi-3-medium-128k-instruct.Q4_K.gguf
# Phi-3-medium-128k-instruct.Q4_K.gguf #llama-2-7b-chat.Q4_K_M.gguf

LLAMA_DISABLE_GPU=false
LLAMA_SEED=1024325
#LLAMA_THREADS=8
LLAMA_USE_FLASH_ATTENTION=false

